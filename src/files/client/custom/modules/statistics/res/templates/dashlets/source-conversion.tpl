<div class="dashlet-content">
    <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse;">
            <colgroup>
                <col style="width:35%;"/>
                <col style="width:18%;"/>
                <col/>
                <col style="width:16%;"/>
            </colgroup>
            <thead>
            <tr style="border-bottom:2px solid #eee;">
                <th style="padding:8px 12px; font-size:11px; color:#999; text-transform:uppercase; letter-spacing:.5px; font-weight:600;">
                    {{translate 'Source' category='fields' scope='Statistics'}}
                </th>
                <th style="padding:8px 12px; font-size:11px; color:#999; text-transform:uppercase; letter-spacing:.5px; font-weight:600; text-align:right;">
                    {{translate 'Converted Leads' scope='Statistics'}}
                </th>
                <th style="padding:8px 12px; font-size:11px; color:#999; text-transform:uppercase; letter-spacing:.5px; font-weight:600;"></th>
                <th style="padding:8px 12px; font-size:11px; color:#999; text-transform:uppercase; letter-spacing:.5px; font-weight:600; text-align:right;">
                    {{translate 'Rate' scope='Statistics'}}
                </th>
            </tr>
            </thead>
            <tbody class="stat-table-body">
            <tr>
                <td colspan="4" class="text-center text-muted" style="padding:20px;">
                    <em>Loading…</em>
                </td>
            </tr>
            </tbody>
        </table>
    </div>

    <div style="margin-top:6px; color:#bbb; font-size:11px; text-align:right; padding:0 12px;">
        <span data-name="footer-text"></span>
    </div>
</div>
